<script>
  // ── Flèche SVG audit → outcomes ──────────────────────────────────
  // Le tronc se dessine du haut vers le bas au scroll.
  // Quand il atteint chaque branche, elle se dessine aussi et le bloc s'allume.

  const trunk   = document.getElementById('arrow-trunk');
  const b1      = document.getElementById('arrow-b1');
  const b2      = document.getElementById('arrow-b2');
  const b3      = document.getElementById('arrow-b3');
  const oc1     = document.getElementById('oc-1');
  const oc2     = document.getElementById('oc-2');
  const oc3     = document.getElementById('oc-3');
  const wrapper = document.querySelector('.outcomes-wrapper');

  // Longueurs des segments (doivent correspondre aux attributs SVG)
  const TRUNK_LEN = 220;
  const BRANCH_LEN = 30;

  // Positions Y (en unités SVG) où chaque branche part du tronc
  const Y_B1 = 60;
  const Y_B2 = 140;
  const Y_B3 = 220;

  function lerp(a, b, t) { return a + (b - a) * Math.max(0, Math.min(1, t)); }

  function updateArrow() {
    if (!wrapper) return;
    const rect = wrapper.getBoundingClientRect();
    const wrapperH = rect.height;
    const winH = window.innerHeight;

    // La "tête" de la flèche suit à 20% du haut de l'écran
    // cursorY = position du curseur (20% du haut) par rapport au top du wrapper
    const cursorViewport = winH * 0.20;
    const cursorInWrapper = cursorViewport - rect.top;

    // Progress = position du curseur dans le wrapper, normalisée sur 30% de sa hauteur (plus rapide)
    const progress = Math.max(0, Math.min(1, cursorInWrapper / (wrapperH * 0.30)));

    // Tronc : strokeDashoffset va de 220 → 0
    trunk.style.strokeDashoffset = TRUNK_LEN * (1 - progress);

    // Position actuelle de la "tête" sur le tronc (en unités SVG 0–220)
    const headY = progress * TRUNK_LEN;

    // Branche 1 (Y=60)
    const prog1 = Math.max(0, Math.min(1, (headY - Y_B1) / 40));
    b1.style.strokeDashoffset = BRANCH_LEN * (1 - prog1);
    if (prog1 >= 1) oc1.classList.add('lit'); else oc1.classList.remove('lit');

    // Branche 2 (Y=140)
    const prog2 = Math.max(0, Math.min(1, (headY - Y_B2) / 40));
    b2.style.strokeDashoffset = BRANCH_LEN * (1 - prog2);
    if (prog2 >= 1) oc2.classList.add('lit'); else oc2.classList.remove('lit');

    // Branche 3 (Y=220)
    const prog3 = Math.max(0, Math.min(1, (headY - Y_B3) / 40));
    b3.style.strokeDashoffset = BRANCH_LEN * (1 - prog3);
    if (prog3 >= 1) oc3.classList.add('lit'); else oc3.classList.remove('lit');
  }

  window.addEventListener('scroll', updateArrow, { passive: true });
  updateArrow();
</script>

<script>
  const container = document.getElementById('fdp-scrub');

  // 3 points individuels + "Projet." d'un bloc
  const parts = [
    { char: '.', cls: 'ellipsis' },
    { char: '.', cls: 'ellipsis' },
    { char: '.', cls: 'ellipsis' },
    { char: ' Projet.', cls: 'projet-word' },
  ];

  parts.forEach(({ char, cls }) => {
    const span = document.createElement('span');
    span.className = 'fdp-scrub-char' + (cls ? ' ' + cls : '');
    span.textContent = char;
    container.appendChild(span);
  });

  const spans = container.querySelectorAll('.fdp-scrub-char');

  // 4 étapes réparties entre 20px et 120px
  const SCROLL_START = 20;
  const SCROLL_END = 120;
  const STEP = (SCROLL_END - SCROLL_START) / spans.length;

  function update() {
    const sy = window.scrollY;
    spans.forEach((span, i) => {
      const threshold = SCROLL_START + i * STEP;
      span.style.opacity = sy >= threshold ? '1' : '0';
    });
    // Masquer le hint dès que le premier point apparaît
    const hint = document.querySelector('.hero-reveal-hint');
    if (hint) hint.classList.toggle('hidden', sy >= SCROLL_START);
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
</script>
